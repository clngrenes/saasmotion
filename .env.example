# Supabase (Dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# Server-only — required for /api/render/* (never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# Inngest (https://app.inngest.com → your app → Signing Key + Event Key)
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Render worker (VPS — kein Vercel Blob nötig)
RENDER_WORKER_URL=
RENDER_WORKER_SECRET=
# Gleichzeitige Renders pro VPS (1 pro ~4 GB RAM, 2 pro ~8 GB)
RENDER_CONCURRENCY=1

# Gemini — KI-Script-Generierung (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Local dev: connect to Inngest Dev Server instead of cloud
# INNGEST_DEV=1

# Render worker process (nur auf dem VPS / lokal)
# RENDER_WORKER_PORT=3100
